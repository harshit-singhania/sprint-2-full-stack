# Used Car Management Backend environment template
#
# Copy these values into your Eclipse or IntelliJ Spring Boot Run Configuration.
# Do not commit a real .env file with production passwords.

# File-based Derby database
DB_URL=jdbc:derby:usedcarsdb;create=true
DB_DRIVER=org.apache.derby.iapi.jdbc.AutoloadedDriver
DB_USERNAME=
DB_PASSWORD=

# JPA / Hibernate
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false
JPA_FORMAT_SQL=false

# Session
SESSION_EXPIRATION_MINUTES=120

# Email notifications
NOTIFICATION_EMAIL_ENABLED=false
NOTIFICATION_EMAIL_FROM=no-reply@usedcars.local

# SMTP settings, only needed when NOTIFICATION_EMAIL_ENABLED=true
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTH=false
SMTP_STARTTLS=false
