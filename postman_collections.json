      "item": [
        {
          "name": "Register Admin (tolerant - singleton)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Admin register returns 200 or already-exists error', function () {",
                  "  pm.expect([200, 400, 409]).to.include(pm.response.code);",
                  "});",
                  "// Admin is a singleton + demo account may pre-exist; either outcome is acceptable."
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{adminUsername}}\",\n  \"name\": \"Demo Admin\",\n  \"phoneNumber\": \"9000000001\",\n  \"email\": \"demoadmin@example.com\",\n  \"password\": \"{{adminPassword}}\",\n  \"role\": \"ADMIN\"\n}"
            }
