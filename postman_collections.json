{
  "info": {
    "name": "Used Car Marketplace - Integration Suite",
    "_postman_id": "a1b2c3d4-0000-4000-8000-usedcarsuite01",
    "description": "End-to-end integration tests for the Used Car Buy & Sell marketplace. Validates every backend endpoint that the Angular frontend (frontend/src/app/core/services/*) depends on. Run sequentially with Newman against a running backend; requests chain via collection variables (tokens, carId, orderId, ticketId).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
          "exec": [
            "// Generate unique, re-runnable usernames once per Newman run.",
            "if (!pm.collectionVariables.get('runId')) {",
            "  const r = Date.now().toString().slice(-7);",
            "  pm.collectionVariables.set('runId', r);",
            "  pm.collectionVariables.set('sellerUsername', 'seller_' + r);",
            "  pm.collectionVariables.set('buyerUsername', 'buyer_' + r);",
            "  pm.collectionVariables.set('sellerPhone', '98' + r.padStart(8, '0'));",
            "  pm.collectionVariables.set('buyerPhone', '97' + r.padStart(8, '0'));",
            "}"
          ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Global assertions applied after every request.",
          "pm.test('Response time is reasonable (< 5s)', function () {",
          "  pm.expect(pm.response.responseTime).to.be.below(5000);",
          "});",
          "pm.test('Content-Type is JSON when body present', function () {",
          "  const len = pm.response.headers.get('Content-Length');",
          "  if (pm.response.text() && pm.response.text().length > 0) {",
          "    pm.expect(pm.response.headers.get('Content-Type') || '').to.include('json');",
          "  }",
          "});"
        ]
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "adminUsername", "value": "demoadmin" },
    { "key": "adminPassword", "value": "Demo@1234x" },
    { "key": "sellerPassword", "value": "Seller@123" },
    { "key": "buyerPassword", "value": "Buyer@123" },
    { "key": "runId", "value": "" },
    { "key": "sellerUsername", "value": "" },
    { "key": "buyerUsername", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "sellerToken", "value": "" },
    { "key": "buyerToken", "value": "" },
    { "key": "carId", "value": "" },
    { "key": "carId2", "value": "" },
    { "key": "orderId", "value": "" },
    { "key": "ticketId", "value": "" }
